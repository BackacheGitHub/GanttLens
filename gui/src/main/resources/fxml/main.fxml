<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ganttlens.gui.MainController"
            fx:id="rootPane"
            prefWidth="1200"
            prefHeight="800">

    <!-- Top Menu Bar -->
    <top>
        <MenuBar>
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem text="Open" onAction="#openFile" />
                        <MenuItem text="Save" onAction="#saveFile" fx:id="saveMenuItem" />
                        <SeparatorMenuItem />
                    </items>
                </Menu>
                <Menu text="Edit">
                    <items>
                        <MenuItem text="Undo" onAction="#undo" fx:id="undoMenuItem" />
                        <MenuItem text="Redo" onAction="#redo" fx:id="redoMenuItem" />
                    </items>
                </Menu>
                <Menu text="Analyze">
                    <items>
                        <MenuItem text="Parse &amp; Analyze" onAction="#parseAndAnalyze" fx:id="parseMenuItem" />
                    </items>
                </Menu>
                <Menu text="View">
                    <items>
                        <MenuItem text="Zoom In" onAction="#zoomIn" />
                        <MenuItem text="Zoom Out" onAction="#zoomOut" />
                        <MenuItem text="Fit to Window" onAction="#fitToWindow" />
                    </items>
                </Menu>
                <Menu text="Help">
                    <items>
                        <MenuItem text="About" onAction="#showAbout" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>


    <!-- Center: Code Editor + Analysis -->
    <center>
        <SplitPane dividerPositions="0.45">
            <items>
                <!-- Code Editor (middle-left column) -->
                <VBox>
                    <Label text="PlantUML Code" styleClass="header-label" />
                    <TextArea fx:id="codeArea"
                              VBox.vgrow="ALWAYS"
                              styleClass="code-area"
                              wrapText="true" />
                    <!-- Bottom buttons: Parse + Save -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <padding>
                            <Insets top="4" right="8" bottom="4" left="8" />
                        </padding>
                        <Button text="Parse" onAction="#parseAndAnalyze" styleClass="parse-button" />
                        <Button text="Save" onAction="#saveFile" styleClass="save-button" />
                    </HBox>
                </VBox>

                <!-- Analysis Tabs (right column) -->
                <TabPane fx:id="analysisTabPane">
                    <tabs>
                        <!-- Gantt Chart Tab -->
                        <Tab text="Gantt Chart" closable="false">
                            <content>
                                <BorderPane>
                                    <!-- Toolbar -->
                                    <top>
                                        <HBox spacing="6" alignment="CENTER_LEFT">
                                            <padding>
                                                <Insets top="4" right="8" bottom="4" left="8" />
                                            </padding>
                                            <Button text="Zoom+" onAction="#zoomIn" />
                                            <Button text="Zoom-" onAction="#zoomOut" />
                                            <Button text="Fit" onAction="#fitToWindow" />
                                        </HBox>
                                    </top>
                                    <!-- Main content: Canvas only (labels rendered in Canvas) -->
                                    <center>
                                        <ScrollPane fx:id="ganttScrollPane"
                                                    fitToHeight="true">
                                            <Canvas fx:id="ganttCanvas"
                                                    width="800" height="600" />
                                        </ScrollPane>
                                    </center>
                                </BorderPane>
                            </content>
                        </Tab>

                        <!-- Statistics Tab -->
                        <Tab text="Statistics" closable="false">
                            <content>
                                <ScrollPane>
                                    <VBox spacing="12">
                                        <padding>
                                            <Insets top="10" right="10" bottom="10" left="10" />
                                        </padding>
                                        <!-- Overview cards -->
                                        <Label text="Project Overview" styleClass="header-label" />
                                        <HBox spacing="16">
                                            <VBox alignment="CENTER" styleClass="stat-card">
                                                <Label fx:id="statTaskCount" text="--" styleClass="stat-value" />
                                                <Label text="Tasks" styleClass="stat-label" />
                                            </VBox>
                                            <VBox alignment="CENTER" styleClass="stat-card">
                                                <Label fx:id="statManDays" text="--" styleClass="stat-value" />
                                                <Label text="Man-days" styleClass="stat-label" />
                                            </VBox>
                                            <VBox alignment="CENTER" styleClass="stat-card">
                                                <Label fx:id="statDuration" text="--" styleClass="stat-value" />
                                                <Label text="Duration (days)" styleClass="stat-label" />
                                            </VBox>
                                        </HBox>
                                        <!-- Critical path -->
                                        <Label text="Critical Path" styleClass="header-label" />
                                        <Label fx:id="statCriticalPath" text="No critical path data" wrapText="true" />
                                        <!-- Overloads -->
                                        <Label text="Overload Warnings" styleClass="header-label" />
                                        <VBox fx:id="overloadBox" spacing="4" />
                                        <!-- Balance Suggestions -->
                                        <Label text="Balance Suggestions" styleClass="header-label" />
                                        <VBox fx:id="suggestionBox" spacing="4" />
                                        <!-- Resource Distribution -->
                                        <Label text="Resource Distribution" styleClass="header-label" />
                                        <VBox fx:id="resourceBox" spacing="4" />
                                    </VBox>
                                </ScrollPane>
                            </content>
                        </Tab>

                        <!-- Workload Tab (placeholder for future) -->
                        <Tab text="Workload" closable="false">
                            <content>
                                <Label text="Workload Heatmap - Coming Soon" />
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>
            </items>
        </SplitPane>
    </center>

    <!-- Bottom: Status Bar -->
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10" />
            </padding>
            <Label fx:id="statusLabel" text="Ready" />
        </HBox>
    </bottom>

</BorderPane>
